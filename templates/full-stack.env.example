# Path to this env file is passed to scripts/install-full-stack.sh

# Runtime repo
RUNTIME_REPO_URL=https://github.com/ski28dev/mtproxy-logs.git
RUNTIME_REF=main
RUNTIME_DIR=/opt/mtproxy-logs

# MTProxy runtime
PORT=443
STATS_PORT=127.0.0.1:8888
FAKE_HOST=www.cloudflare.com
RUN_USER=nobody
ENV_FILE=/etc/mtproxy/mtproxy.env
MANAGED_LIST=/etc/mtproxy/managed_secrets.list
LOG_FILE=/var/log/mtproxy/mtproxy.log

# Panel
APP_BASE_DIR=/opt/mtproxy-logs-panel
PANEL_PORT=8088
API_PORT=3210
PANEL_HOST=127.0.0.1
PANEL_ORIGIN=http://127.0.0.1:8088
PANEL_SERVER_NAMES=_

# Database and admin
DB_NAME=mtproxy_panel
DB_USER=mtproxy_panel
DB_PASSWORD=change_me
JWT_SECRET=change_me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Panel <-> runtime integration
MTPROXY_HOST=127.0.0.1
MTPROXY_PORT=443
MTPROXY_FAKE_HOST=www.cloudflare.com
MTPROXY_SYNC_COMMAND=sudo /usr/local/bin/mtproxy-panel-sync
MTPROXY_LOG_PATH=/var/log/mtproxy/mtproxy.log
MTPROXY_LOG_STATE_PATH=/var/lib/mtproxy-panel/log-state.json
MTPROXY_SLOT_WINDOW_HOURS=72

# Optional output file
ROOT_FULL_INFO_PATH=/root/mtproxy-full-stack-info.txt
